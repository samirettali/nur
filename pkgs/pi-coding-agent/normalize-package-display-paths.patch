+++ b/packages/coding-agent/src/config.ts
@@ -350,6 +350,22 @@ export function getPackageDir(): string {
 	// Fallback (shouldn't happen)
 	return __dirname;
 }
+
+export function getDisplayPackageDir(): string {
+	return process.env.PI_PACKAGE_DIR ? normalizePath(process.env.PI_PACKAGE_DIR) : getPackageDir();
+}
+
+export function normalizePackageDisplayPath(path: string): string {
+	const actualPackageDir = resolve(getPackageDir());
+	const resolvedPath = resolve(path);
+	const displayPackageDir = getDisplayPackageDir();
+	if (resolvedPath === actualPackageDir) return displayPackageDir;
+	const actualPackageDirPrefix = actualPackageDir.endsWith(sep) ? actualPackageDir : `${actualPackageDir}${sep}`;
+	if (resolvedPath.startsWith(actualPackageDirPrefix)) {
+		return join(displayPackageDir, resolvedPath.slice(actualPackageDirPrefix.length));
+	}
+	return path;
+}
 
