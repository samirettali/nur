-	}
-
-	if (isBunBinary) {
+	} else if (isBunBinary) {
 		// Bun binary: process.execPath points to the compiled executable
 		return dirname(process.execPath);
 	}
@@ -100,6 +104,21 @@
 	}
 	// Fallback (shouldn't happen)
 	return __dirname;
+}
+
+export function getDisplayPackageDir(): string {
+	return process.env.PI_PACKAGE_DIR ? expandHomePath(process.env.PI_PACKAGE_DIR) : getPackageDir();
+}
+
+export function normalizePackageDisplayPath(path: string): string {
+	const actualPackageDir = resolve(getPackageDir());
+	const resolvedPath = resolve(path);
+	const displayPackageDir = getDisplayPackageDir();
+	if (resolvedPath === actualPackageDir) return displayPackageDir;
+	if (resolvedPath.startsWith(`${actualPackageDir}/`)) {
+		return join(displayPackageDir, resolvedPath.slice(actualPackageDir.length + 1));
+	}
+	return path;
 }
 
